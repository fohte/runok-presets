#!/usr/bin/env bash
set -euo pipefail

# Run E2E tests for runok presets.
# Extracts test cases from #[test] comments in preset YAML files and verifies
# each command's decision against expected values using `runok check`.
#
# Format: #[test] <decision>: <command>
#
# Dependencies: runok, jq

repo_root="$(cd "$(dirname "$0")/.." && pwd)"

failures=0
total=0

# Run tests in an isolated tmpdir to avoid interference from
# runok.local.yml or ancestor directory configs.
empty_xdg=$(mktemp -d)
testdir=$(mktemp -d)
trap 'rm -r "$empty_xdg" "$testdir"' EXIT

# Copy preset files into testdir.
for f in "$repo_root"/*.yml; do
  bn=$(basename "$f")
  [ "$bn" = "runok.yml" ] || [ "$bn" = "runok.local.yml" ] && continue
  cp "$f" "$testdir/$bn"
done

# Extract and run #[test] comments from each preset YAML file.
for f in "$repo_root"/*.yml; do
  bn=$(basename "$f")
  [ "$bn" = "runok.yml" ] || [ "$bn" = "runok.local.yml" ] && continue

  while IFS= read -r line; do
    # Parse: #[test] <decision>: <command>
    # Strip leading whitespace and the #[test] prefix, then split on first ": "
    body="${line#*\#\[test\] }"
    expected="${body%%: *}"
    command="${body#*: }"

    # Build runok.yml for testdir.
    # If the file has #[test:extends] directives, generate a wrapper config
    # that extends both the target file and the additional presets.
    extends_line=$(grep '#\[test:extends\]' "$f" | head -1 || true)
    if [ -n "$extends_line" ]; then
      extra="${extends_line#*\#\[test:extends\] }"
      # Build YAML extends list: the file itself + extra presets
      {
        echo "extends:"
        echo "  - ./$bn"
        IFS=',' read -ra parts <<< "$extra"
        for part in "${parts[@]}"; do
          part=$(echo "$part" | xargs) # trim whitespace
          echo "  - $part"
        done
      } > "$testdir/runok.yml"
    else
      cp "$testdir/$bn" "$testdir/runok.yml"
    fi

    # Run runok check with isolated config:
    # - XDG_CONFIG_HOME points to empty dir (no global config)
    # - Working directory is testdir (isolated from project and ancestor configs)
    # Pipe via stdin to preserve shell quoting (e.g. bash -c "cat /etc/hosts").
    result=$(cd "$testdir" && echo "$command" | XDG_CONFIG_HOME="$empty_xdg" runok check --output-format json 2> /dev/null) || true
    actual=$(echo "$result" | jq -r '.decision')

    total=$((total + 1))
    if [ "$actual" != "$expected" ]; then
      failures=$((failures + 1))
      echo "FAIL: $command"
      echo "  config:   $bn"
      echo "  expected: $expected"
      echo "  actual:   $actual"
    fi
  done < <(grep '#\[test\]' "$f")
done

if [ "$total" -eq 0 ]; then
  echo "ERROR: no test cases found"
  exit 1
fi

echo ""
echo "$((total - failures))/$total passed"
[ "$failures" -eq 0 ] && exit 0 || exit 1
